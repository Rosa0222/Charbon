function Avatar({ client }) {
  return <div style={s.initials(client.color)}>{client.initials}</div>;
}

function Badge({ status }) {
  return <span style={s.pill(statusBg[status], statusTxt[status])}>{status}</span>;
}

function NavBar({ tab, setTab }) {
  const tabs = [
    { id:"home", icon:"ti-home", label:"Home" },
    { id:"dashboard", icon:"ti-layout-dashboard", label:"Dashboard" },
    { id:"clients", icon:"ti-users", label:"Clients" },
    { id:"sessions", icon:"ti-calendar", label:"Sessions" },
    { id:"resources", icon:"ti-folder", label:"Resources" },
    { id:"messages", icon:"ti-message-circle", label:"Messages" },
  ];
  return (
    <nav style={s.nav}>
      {tabs.map(t => (
        <div key={t.id} style={s.navItem(tab===t.id)} onClick={()=>setTab(t.id)}>
          <i className={`ti ${t.icon}`} style={s.navIcon} aria-hidden="true"/>
          <span>{t.label}</span>
        </div>
      ))}
    </nav>
  );
}

