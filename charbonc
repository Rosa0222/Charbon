              <div>
                <div style={{ fontSize:11, fontWeight:600, color:C.muted, marginBottom:5 }}>FILE TITLE</div>
                <input value={form.title} onChange={e=>setForm({...form,title:e.target.value})} placeholder="e.g. Signed coaching agreement" style={s.input}/>
              </div>
              <div>
                <div style={{ fontSize:11, fontWeight:600, color:C.muted, marginBottom:5 }}>CATEGORY</div>
                <select value={form.category} onChange={e=>setForm({...form,category:e.target.value})}
                  style={{ ...s.input, appearance:"none" }}>
                  {CATEGORIES.map(c=><option key={c}>{c}</option>)}
                </select>
              </div>
              <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:10 }}>
                <div>
                  <div style={{ fontSize:11, fontWeight:600, color:C.muted, marginBottom:5 }}>FILE TYPE</div>
                  <select value={form.type} onChange={e=>setForm({...form,type:e.target.value})} style={{ ...s.input, appearance:"none" }}>
