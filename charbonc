function FolderSection({ clientId }) {
  const [docs, setDocs] = useState(initDocs[clientId] || []);
  const [openCats, setOpenCats] = useState(["Agreement"]);
  const [showModal, setShowModal] = useState(false);
  const [form, setForm] = useState({ title:"", category:"Agreement", type:"PDF", desc:"", uploadedBy:"Coach" });

  const toggle = (cat) => setOpenCats(prev => prev.includes(cat) ? prev.filter(c=>c!==cat) : [...prev, cat]);

  const addDoc = () => {
    if (!form.title.trim()) return;
    const now = new Date().toLocaleDateString("en",{month:"short",day:"numeric",year:"numeric"});
    setDocs(prev=>[...prev, { id:`D${Date.now()}`, ...form, date:now, signed:false, url:"#" }]);
    setForm({ title:"", category:"Agreement", type:"PDF", desc:"", uploadedBy:"Coach" });
    setShowModal(false);
  };

  return (
    <div style={{ marginTop:16 }}>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:14 }}>
        <div style={{ fontSize:12, color:C.muted }}>Shared between coach & client</div>
        <button onClick={()=>setShowModal(true)}
          style={{ background:C.charcoal, color:C.cream, border:"none", borderRadius:99, padding:"7px 14px", fontSize:12, fontWeight:600, cursor:"pointer", display:"flex", alignItems:"center", gap:6 }}>
          <i className="ti ti-plus" style={{ fontSize:13 }} aria-hidden="true"/> Add file
        </button>
      </div>

      {CATEGORIES.map(cat=>{
        const catDocs = docs.filter(d=>d.category===cat);
        const isOpen = openCats.includes(cat);
        return (
          <div key={cat} style={{ marginBottom:10 }}>
            <div onClick={()=>toggle(cat)}
              style={{ background:catBg[cat], border:`0.5px solid ${catColor[cat]}33`, borderRadius: isOpen ? "14px 14px 0 0" : 14, padding:"12px 14px", display:"flex", alignItems:"center", gap:10, cursor:"pointer" }}>
              <div style={{ width:32, height:32, borderRadius:8, background:catColor[cat]+"22", border:`1px solid ${catColor[cat]}44`, display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
                <i className={`ti ${catIcon[cat]}`} style={{ fontSize:15, color:catColor[cat] }} aria-hidden="true"/>
              </div>
              <div style={{ flex:1 }}>
                <div style={{ fontSize:13, fontWeight:600, color:C.charcoal }}>{cat}</div>
                <div style={{ fontSize:10, color:C.muted }}>{catDocs.length} {catDocs.length===1?"file":"files"}</div>
              </div>
              <i className={`ti ${isOpen?"ti-chevron-up":"ti-chevron-down"}`} style={{ fontSize:14, color:C.muted }} aria-hidden="true"/>
