      <div style={{ marginTop:8 }}>
        {shown.map(r=>{
          const cl = clients.find(c=>c.id===r.clientId);
          return (
            <div key={r.id} style={{ background:C.white, border:`0.5px solid ${C.border}`, borderRadius:14, padding:"14px 16px", marginBottom:10 }}>
              <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:6 }}>
                <span style={{ fontSize:13, fontWeight:600, color:C.charcoal, flex:1, paddingRight:8 }}>{r.title}</span>
                <span style={s.pill(typeColor[r.type], typeText[r.type])}>{r.type}</span>
              </div>
              <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:8 }}>
                <div style={s.initials(cl.color)}>{cl.initials}</div>
                <div style={{ fontSize:11, color:C.muted }}>{r.client} · {r.date}</div>
              </div>
              <div style={{ fontSize:12, color:C.muted, marginBottom:10 }}>{r.desc}</div>
              <div style={{ background:C.goldLight, borderRadius:99, padding:"8px 0", textAlign:"center", fontSize:12, fontWeight:600, color:C.goldDark, cursor:"pointer" }}>
                <i className="ti ti-external-link" style={{ marginRight:6, fontSize:12 }} aria-hidden="true"/> Open resource
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}

function MessagesScreen() {
  const [selected, setSelected] = useState(null);
  if (selected) {
    const cl = clients.find(c=>c.id===selected);
    const thread = messages.filter(m=>m.clientId===selected);
    return (
      <div>
        <div style={{ background:C.charcoal, padding:"48px 20px 16px" }}>
          <button onClick={()=>setSelected(null)} style={{ background:"none", border:"none", color:C.gold, fontSize:13, cursor:"pointer", padding:0, marginBottom:12, display:"flex", alignItems:"center", gap:6 }}>
            <i className="ti ti-arrow-left" aria-hidden="true"/> Messages
          </button>
          <div style={{ display:"flex", alignItems:"center", gap:12 }}>
            <Avatar client={cl}/>
            <div style={{ fontSize:15, fontWeight:600, color:C.cream }}>{cl.name}</div>
          </div>
        </div>
        <div style={{ padding:"16px 16px 100px", display:"flex", flexDirection:"column", gap:10 }}>
          {thread.map(m=>(
            <div key={m.id} style={{ display:"flex", justifyContent: m.role==="Coach" ? "flex-end" : "flex-start" }}>
              <div style={{ maxWidth:"80%", background: m.role==="Coach" ? C.charcoal : C.white, border:`0.5px solid ${C.border}`, borderRadius: m.role==="Coach" ? "14px 14px 4px 14px" : "14px 14px 14px 4px", padding:"10px 14px" }}>
                <div style={{ fontSize:11, color: m.role==="Coach" ? C.gold : C.muted, fontWeight:600, marginBottom:4 }}>{m.role}</div>
                <div style={{ fontSize:13, color: m.role==="Coach" ? C.cream : C.charcoal, lineHeight:1.5 }}>{m.text}</div>
                <div style={{ fontSize:10, color:C.muted, marginTop:6 }}>{m.time}</div>
              </div>
            </div>
          ))}
        </div>
        <div style={{ position:"fixed", bottom:80, left:"50%", transform:"translateX(-50%)", width:"100%", maxWidth:430, padding:"12px 16px", background:C.cream, borderTop:`0.5px solid ${C.border}` }}>
          <div style={{ display:"flex", gap:8 }}>
            <input placeholder="Type a message…" style={{ ...s.input, flex:1 }}/>
            <button style={{ background:C.gold, border:"none", borderRadius:10, padding:"0 16px", cursor:"pointer", color:C.charcoal, fontWeight:600, fontSize:13 }}>Send</button>
          </div>
        </div>
      </div>
    );
  }

  const threads = clients.map(c=>({
    ...c,
    lastMsg: messages.filter(m=>m.clientId===c.id).at(-1),
    unread: messages.filter(m=>m.clientId===c.id && !m.read).length,
  })).filter(c=>c.lastMsg);

  return (
    <div style={{ padding:"0 16px" }}>
      <div style={{ marginTop:16 }}>
        {threads.map(c=>(
          <div key={c.id} style={{ ...s.card, cursor:"pointer", display:"flex", alignItems:"center", gap:12 }} onClick={()=>setSelected(c.id)}>
            <div style={{ position:"relative" }}>
              <Avatar client={c}/>
              {c.unread > 0 && <div style={{ position:"absolute", top:-2, right:-2, width:16, height:16, background:C.coral, borderRadius:"50%", fontSize:9, color:C.white, display:"flex", alignItems:"center", justifyContent:"center", fontWeight:700 }}>{c.unread}</div>}
            </div>
            <div style={{ flex:1, minWidth:0 }}>
              <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center" }}>
                <span style={{ fontSize:13, fontWeight:600, color:C.charcoal }}>{c.name}</span>
                <span style={{ fontSize:10, color:C.muted }}>{c.lastMsg.time}</span>
              </div>
              <div style={{ fontSize:12, color:C.muted, marginTop:2, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>
                {c.lastMsg.role==="Coach" ? "You: " : ""}{c.lastMsg.text}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

function Header({ tab }) {
  const titles = { home:null, dashboard:"Dashboard", clients:"My Clients", sessions:"Sessions", resources:"Resources", messages:"Messages" };
  if (!titles[tab]) return null;
  return (
    <div style={s.header}>
      <div>
        <div style={s.headerTitle}>{titles[tab]}</div>
        <div style={s.headerSub}>CHARBON & CO</div>
      </div>
      <div style={{ width:36, height:36, borderRadius:"50%", background:C.gold, display:"flex", alignItems:"center", justifyContent:"center", fontSize:13, fontWeight:700, color:C.charcoal }}>C</div>
    </div>
  );
}

export default function App() {
  const [tab, setTab] = useState("home");
  useEffect(()=>{
    const link=document.createElement("link");
    link.rel="stylesheet";
    link.href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/tabler-icons.min.css";
    document.head.appendChild(link);
    const font=document.createElement("link");
    font.rel="stylesheet";
    font.href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap";
    document.head.appendChild(font);
  },[]);

  return (
    <div style={s.app}>
      <div style={s.shell}>
        <Header tab={tab}/>
        <div style={s.content}>
          {tab==="home"      && <HomeScreen/>}
          {tab==="dashboard" && <DashboardScreen/>}
          {tab==="clients"   && <ClientsScreen/>}
          {tab==="sessions"  && <SessionsScreen/>}
          {tab==="resources" && <ResourcesScreen/>}
          {tab==="messages"  && <MessagesScreen/>}
        </div>
        <NavBar tab={tab} setTab={setTab}/>
      </div>
    </div>
  );
}
